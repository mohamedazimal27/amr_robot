<?xml version="1.0"?>
<robot name="amr_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="base_l"     value="0.265"/>
  <xacro:property name="base_w"     value="0.265"/>
  <xacro:property name="base_h"     value="0.130"/>
  <xacro:property name="base_mass"  value="10.0"/>
  <xacro:property name="wheel_r"    value="0.0425"/>
  <xacro:property name="wheel_t"    value="0.018"/>
  <xacro:property name="wheel_mass" value="0.5"/>
  <xacro:property name="wheel_sep"  value="0.28"/>
  <xacro:property name="caster_r"   value="0.015"/>

  <!-- ═══════════════════════════════════════════════
       TF CHAIN:
       odom → base_footprint → base_link → sensors
       
       base_footprint: on the ground (z=0)
       base_link: center at wheel_r above ground
       wheel joints: at z=0 relative to base_link
         (wheel axle = base_link center = wheel_r above ground)
       ═══════════════════════════════════════════════ -->

  <!-- <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_r}" rpy="0 0 0"/>
  </joint> -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_l} ${base_w} ${base_h}"/>
      </geometry>
      <material name="dark_blue">
        <color rgba="0.08 0.18 0.55 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_l} ${base_w} ${base_h}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia
        ixx="${base_mass*(base_w*base_w+base_h*base_h)/12}"
        ixy="0" ixz="0"
        iyy="${base_mass*(base_l*base_l+base_h*base_h)/12}"
        iyz="0"
        izz="${base_mass*(base_l*base_l+base_w*base_w)/12}"/>
    </inertial>
  </link>

  <link name="top_deck">
    <visual>
      <geometry>
        <box size="${base_l-0.01} ${base_w-0.01} 0.006"/>
      </geometry>
      <material name="charcoal">
        <color rgba="0.22 0.22 0.25 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_l-0.01} ${base_w-0.01} 0.006"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="top_deck_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="top_deck"/>
    <origin xyz="0 0 ${base_h/2+0.003}" rpy="0 0 0"/>
  </joint>

  <link name="arm_mount">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="orange">
        <color rgba="0.85 0.45 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="arm_mount_joint" type="fixed">
    <parent link="top_deck"/>
    <child  link="arm_mount"/>
    <origin xyz="-0.05 0 0.028" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════
       WHEELS
       Z=0 relative to base_link because:
       base_link center = wheel_r above ground
       wheel axle = wheel_r above ground
       therefore wheel axle Z offset from base_link = 0
       ═══════════════════════════════════════════════ -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_r}" length="${wheel_t}"/>
      </geometry>
      <material name="tire_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_r}" length="${wheel_t}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${wheel_mass*(3*wheel_r*wheel_r+wheel_t*wheel_t)/12}"
        ixy="0" ixz="0"
        iyy="${wheel_mass*(3*wheel_r*wheel_r+wheel_t*wheel_t)/12}"
        iyz="0"
        izz="${wheel_mass*wheel_r*wheel_r/2}"/>
    </inertial>
  </link>

<joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_sep/2} ${-base_h/2}" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 -1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_r}" length="${wheel_t}"/>
      </geometry>
      <material name="tire_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_r}" length="${wheel_t}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia
        ixx="${wheel_mass*(3*wheel_r*wheel_r+wheel_t*wheel_t)/12}"
        ixy="0" ixz="0"
        iyy="${wheel_mass*(3*wheel_r*wheel_r+wheel_t*wheel_t)/12}"
        iyz="0"
        izz="${wheel_mass*wheel_r*wheel_r/2}"/>
    </inertial>
  </link>

<joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 ${-wheel_sep/2} ${-base_h/2}" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 -1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ═══════════════════════════════════════════════
       CASTER
       Z = -(base_h/2) drops to bottom of base_link
       Then caster_r raises it so bottom touches ground
       But base_link center is at wheel_r so:
       caster bottom = wheel_r - base_h/2 + caster_r
       This should equal 0 (ground level)
       wheel_r=0.0425, base_h/2=0.065, caster_r=0.015
       0.0425 - 0.065 + 0.015 = -0.0075 (slightly above)
       Use -base_h/2 + caster_r to get close enough
       ═══════════════════════════════════════════════ -->
  <!-- REAR CASTER -->
  <link name="rear_caster_wheel">
    <visual>
      <geometry><sphere radius="${caster_r}"/></geometry>
      <material name="light_gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_r}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia
        ixx="0.000025" ixy="0" ixz="0"
        iyy="0.000025" iyz="0"
        izz="0.000025"/>
    </inertial>
  </link>

  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="rear_caster_wheel"/>
    <origin xyz="${-(base_l/2-0.04)} 0 ${-base_h/2 - wheel_r + caster_r}" rpy="0 0 0"/>
  </joint>

  <!-- FRONT CASTER -->
  <link name="front_caster_wheel">
    <visual>
      <geometry><sphere radius="${caster_r}"/></geometry>
      <material name="light_gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_r}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia
        ixx="0.000025" ixy="0" ixz="0"
        iyy="0.000025" iyz="0"
        izz="0.000025"/>
    </inertial>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="front_caster_wheel"/>
    <origin xyz="${(base_l/2-0.04)} 0 ${-base_h/2 - wheel_r + caster_r}" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="scan_red">
        <color rgba="0.9 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.0 0.0 ${base_h/2+0.04}" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.02 0.08 0.02"/></geometry>
      <material name="cam_black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="camera_optical_frame"/>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${base_l/2-0.01} 0 ${base_h/2-0.01}" rpy="0 0.2618 0"/>
  </joint>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
      <topic>/camera/image_raw</topic>
      <gz_frame_id>camera_optical_frame</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo reference="rear_caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="front_caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="left_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.001</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

<gazebo>
  <plugin filename="gz-sim-diff-drive-system"
          name="gz::sim::systems::DiffDrive">

    <left_joint>left_wheel_joint</left_joint>
    <right_joint>right_wheel_joint</right_joint>

    <wheel_separation>${wheel_sep}</wheel_separation>
    <wheel_radius>${wheel_r}</wheel_radius>

    <topic>/cmd_vel</topic>

    <odom_topic>odom</odom_topic>
    <tf_topic>/tf</tf_topic>

    <frame_id>odom</frame_id>
    <child_frame_id>base_footprint</child_frame_id>

    <odom_publish_frequency>30</odom_publish_frequency>

    <max_linear_velocity>1.0</max_linear_velocity>
    <max_angular_velocity>1.5</max_angular_velocity>
    <max_linear_acceleration>1.0</max_linear_acceleration>
    <max_angular_acceleration>1.5</max_angular_acceleration>

  </plugin>

  <plugin filename="gz-sim-joint-state-publisher-system"
          name="gz::sim::systems::JointStatePublisher">
    <topic>joint_states</topic>
    <joint_name>left_wheel_joint</joint_name>
    <joint_name>right_wheel_joint</joint_name>
  </plugin>
</gazebo>

</robot>
